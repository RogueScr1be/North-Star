# Analytics Configuration (Phase 3.8)
# PostHog API Key for remote event tracking
# If not set, analytics will use console logging only
# To enable remote tracking:
# 1. Create a PostHog account at https://posthog.com
# 2. Get your API key from PostHog dashboard
# 3. Set the value below
# 4. Include PostHog JS SDK in index.html (see comments there)
VITE_POSTHOG_KEY=phc_your_api_key_here

# Alternatively, for self-hosted PostHog:
# VITE_POSTHOG_KEY=phc_your_key
# VITE_POSTHOG_HOST=https://your-posthog-instance.com

# D3 Layout Engine (Phase 6.0+)
# Set to 'true' to enable D3 Dynamic layout mode (experimental)
# Default: 'false' (Curated/API layout only)
VITE_LAYOUT_ENGINE_ENABLED=false

# API Base URL (Phase 7.1+)
# Backend API endpoint for graph data and Ask-the-Graph
VITE_API_BASE_URL=https://your-backend-url/api

# Demo Mode (Phase B+)
# Set to 'true' to enable full-screen constellation demo
VITE_DEMO_MODE=true

# Visual Immersion Upgrade (Phase 4A/4B, Experimental)
# Billboard visual polish: black-glass HUD aesthetic
VITE_BILLBOARD_VISUAL_POLISH=true
# Pulsar node geometry: luminous core + glow rings + animation
VITE_PULSAR_NODES_ENABLED=true
# Pulsar animation enable/disable (independent of geometry)
VITE_PULSAR_ANIMATION_ENABLED=true
# Focus dimming: dim unrelated nodes when selection active
VITE_FOCUS_DIMMING_ENABLED=true
# Liquid silk panel reveal: smooth fade + drift animation
VITE_LIQUID_PANEL_REVEAL_ENABLED=true
# Camera focus on selection: auto-sweep to selected node (currently disabled by default)
# WARNING: High-risk feature. Enable only after Phase 4B QA passes
VITE_FOCUS_CAMERA_ON_SELECTION=false

# Projected DOM Anchored Panels (Phase 3+, Experimental)
# Set to 'true' to enable projected DOM panels anchored to selected nodes/projects
# Panels render outside Three.js canvas as screen-space overlays, follow camera movement continuously
# Architecture: NOT using Three.js CSS3DRenderer; purely DOM overlay with 3D→2D projection via camera.project()
# Default: 'false' (disabled until QA passes; SelectionPanel used instead)
VITE_CSS3D_PANELS_ENABLED=false
