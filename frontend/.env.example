# Analytics Configuration (Phase 3.8)
# PostHog API Key for remote event tracking
# If not set, analytics will use console logging only
# To enable remote tracking:
# 1. Create a PostHog account at https://posthog.com
# 2. Get your API key from PostHog dashboard
# 3. Set the value below
# 4. Include PostHog JS SDK in index.html (see comments there)
VITE_POSTHOG_KEY=phc_your_api_key_here

# Alternatively, for self-hosted PostHog:
# VITE_POSTHOG_KEY=phc_your_key
# VITE_POSTHOG_HOST=https://your-posthog-instance.com
