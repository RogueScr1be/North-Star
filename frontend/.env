# Phase 0: Demo Environment Configuration (Deterministic, No Telemetry)
# PostHog disabled for demo (zero telemetry)
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST=https://us.posthog.com

# Phase 0: D3 Layout Disabled for Demo (API/Curated only)
# Set to 'false' to disable D3 Dynamic layout, hide toggle
VITE_LAYOUT_ENGINE_ENABLED=false

# Phase 0: API Base URL (Production Backend)
VITE_API_BASE_URL=https://north-star-backend-production-83d2.up.railway.app/api

# Phase B: Demo Mode (Constellation-first UI)
# Set to 'true' to enable full-screen constellation demo mode
VITE_DEMO_MODE=true

# Phase 2: Pulsar Node Design (Experimental Visual Mode)
# Set to 'false' to disable glow rings + animation on nodes (Phase 2 implementation, default off)
VITE_PULSAR_NODES_ENABLED=false

# Phase 3: Projected DOM Anchored Panels (Experimental DOM Overlay)
# Set to 'true' to enable projected DOM panels anchored to selected nodes/projects
# Panels render in 3D world space using Drei <Html> component, following camera movement automatically
# NOT using Three.js CSS3DRenderer; uses R3F/Drei for 3D→2D projection with automatic camera tracking
# Default: false (disabled until QA passes)
VITE_CSS3D_PANELS_ENABLED=false

# Phase 4C: Camera Focus on Selection (Gated Feature)
# When true: selecting a node/project smoothly animates camera to frame selection + connected context
# When false: no camera animation on selection (Phase 3.4 effect is disabled)
# Gesture cancellation: pointer/wheel/pan interrupts animation but preserves selection + billboard
# Default: false (feature disabled, waiting for QA validation)
VITE_FOCUS_CAMERA_ON_SELECTION=false
