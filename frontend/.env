# Phase 0: Demo Environment Configuration (Deterministic, No Telemetry)
# PostHog disabled for demo (zero telemetry)
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST=https://us.posthog.com

# Phase 0: D3 Layout Disabled for Demo (API/Curated only)
# Set to 'false' to disable D3 Dynamic layout, hide toggle
VITE_LAYOUT_ENGINE_ENABLED=false

# Phase 0: API Base URL (Production Backend)
VITE_API_BASE_URL=https://north-star-backend-production-83d2.up.railway.app/api

# Phase B: Demo Mode (Constellation-first UI)
# Set to 'true' to enable full-screen constellation demo mode
VITE_DEMO_MODE=true
