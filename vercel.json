{
  "buildCommand": "npm run build --workspace=frontend",
  "installCommand": "npm ci && npm ci --workspace=frontend",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_LAYOUT_ENGINE_ENABLED": "true"
  },
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
